{
  "Urls": "http://0.0.0.0:7180;https://0.0.0.0:7553",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Node": {
    "Name": "MagicAiNode",
    "GatewayName": "MagicAiGateway",
    "AdvertisedBaseUri": "https://localhost:7553",
    "StaticGateways": [
      "https://localhost:7443"
    ],
    "HealthyPollSeconds": 10,
    "OfflinePollSeconds": 3,
    "HeartbeatSeconds": 5,
    "Backends": [
      {
        "Id": "vllm-local",
        "Name": "Local vLLM",
        "Kind": "Vllm",
        "BaseUri": "http://localhost:8000",
        "ApiKey": null,
        "Enabled": false,
        "AllowInvalidServerCertificate": false
      },
      {
        "Id": "llama-cpp-local",
        "Name": "Local llama.cpp",
        "Kind": "LlamaCpp",
        "BaseUri": "http://localhost:8081",
        "ApiKey": null,
        "Enabled": true,
        "AllowInvalidServerCertificate": false
      }
    ]
  },
  "Fabric": {
    "Security": {
      "StateDirectory": ".magic-ai/node",
      "PairingMode": "ApprovalRequired",
      "EnrollmentToken": null,
      "AllowInsecureLoopback": true,
      "LoopbackToken": null,
      "PairingServerCertificateMode": "TrustOnFirstUse"
    },
    "Discovery": {
      "Enabled": true,
      "GatewayServiceType": "_magicaigw._tcp",
      "NodeServiceType": "_magicainode._tcp",
      "AdvertisedHttpsPort": 7553
    },
    "Queue": {
      "MaxConcurrentRequestsPerModel": 64,
      "MaxQueuedRequestsPerModel": 256,
      "MaximumQueueWaitSeconds": 120
    }
  }
}
