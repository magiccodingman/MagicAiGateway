{
  "Urls": "http://0.0.0.0:7080;https://0.0.0.0:7443",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Gateway": {
    "Name": "MagicAiGateway",
    "AdvertisedBaseUri": "https://localhost:7443",
    "StaticNodes": [],
    "HeartbeatLeaseSeconds": 20
  },
  "Fabric": {
    "Security": {
      "StateDirectory": ".magic-ai/gateway",
      "PairingMode": "ApprovalRequired",
      "EnrollmentToken": null,
      "AdminToken": null,
      "AllowInsecureLoopback": true,
      "LoopbackToken": null,
      "CertificateLifetimeDays": 730,
      "PairingServerCertificateMode": "TrustOnFirstUse"
    },
    "Discovery": {
      "Enabled": true,
      "GatewayServiceType": "_magicaigw._tcp",
      "NodeServiceType": "_magicainode._tcp",
      "AdvertisedHttpsPort": 7443
    },
    "Queue": {
      "MaxConcurrentRequestsPerModel": 64,
      "MaxQueuedRequestsPerModel": 256,
      "MaximumQueueWaitSeconds": 120
    }
  }
}
